generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GenerationStatus {
  UNQUEUED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReviewStatus {
  UNREVIEWED
  VERIFIED
  SOLUTION_INCORRECT
  UNSOLVABLE
}

model Problem {
  id        String   @id @default(cuid())
  contestId Int
  index     String // e.g. "A", "B1"
  name      String
  rating    Int?
  tags      String[] // e.g. ["dp", "greedy"]

  generationStatus   GenerationStatus @default(PENDING)
  generationAttempts Int              @default(0)
  reviewStatus       ReviewStatus     @default(UNREVIEWED)
  requested          Boolean          @default(false)

  // Tracks which provider/model generated this problem's content
  generatedByProvider String? // e.g. "anthropic", "openai"
  generatedByModel    String? // e.g. "claude-opus-4-6", "gpt-5-4"

  hints     Hint[]
  editorial Editorial?
  solution  Solution?
  reports   Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contestId, index])
}

model Hint {
  id      String @id @default(cuid())
  order   Int // 1-5
  content String @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([problemId, order])
}

model Editorial {
  id      String @id @default(cuid())
  content String @db.Text

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Solution {
  id      String @id @default(cuid())
  content String @db.Text // C++ code

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Report {
  id     String  @id @default(cuid())
  reason String? @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ModelConfig {
  id          String  @id @default(cuid())
  provider    String // e.g. "anthropic", "openai"
  modelId     String // e.g. "claude-opus-4-6", "gpt-5-4"
  displayName String // e.g. "Claude Opus 4.6"
  effort      String? // e.g. "low", "medium", "high" — provider-native reasoning effort
  isActive    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, modelId])
}
