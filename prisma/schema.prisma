generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GenerationStatus {
  UNQUEUED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReviewStatus {
  UNREVIEWED
  VERIFIED
  SOLUTION_INCORRECT
}

model Problem {
  id        String   @id @default(cuid())
  contestId Int
  index     String // e.g. "A", "B1"
  name      String
  rating    Int?
  tags      String[] // e.g. ["dp", "greedy"]

  generationStatus   GenerationStatus @default(UNQUEUED)
  generationAttempts Int              @default(0)
  reviewStatus       ReviewStatus     @default(UNREVIEWED)

  hints     Hint[]
  editorial Editorial?
  solution  Solution?
  reports   Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contestId, index])
}

model Hint {
  id      String @id @default(cuid())
  order   Int // 1-5
  content String @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([problemId, order])
}

model Editorial {
  id      String @id @default(cuid())
  content String @db.Text

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Solution {
  id      String @id @default(cuid())
  content String @db.Text // C++ code

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Report {
  id     String  @id @default(cuid())
  reason String? @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
