generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QueueState {
  BACKLOG
  READY
}

enum RunState {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
}

enum ReviewStatus {
  UNREVIEWED
  VERIFIED
  INCORRECT
  UNSOLVABLE
}

model Problem {
  id        String   @id @default(cuid())
  contestId Int
  index     String
  name      String
  rating    Int?
  tags      String[]

  queueState          QueueState   @default(BACKLOG)
  runState            RunState     @default(IDLE)
  generationAttempts  Int          @default(0)
  reviewStatus        ReviewStatus @default(UNREVIEWED)
  requestedCount      Int          @default(0)
  generationStartedAt DateTime?
  lastGenerationError String?      @db.Text

  generatedByDisplayName String?

  hints     Hint[]
  editorial Editorial?
  solution  Solution?
  reports   Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contestId, index])
  @@index([queueState, runState, generationAttempts])
  @@index([runState, generationStartedAt])
  @@index([requestedCount, updatedAt])
}

model Hint {
  id      String @id @default(cuid())
  order   Int
  content String @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, order])
}

model Editorial {
  id      String @id @default(cuid())
  content String @db.Text

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Solution {
  id      String @id @default(cuid())
  content String @db.Text

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Report {
  id     String  @id @default(cuid())
  reason String? @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model DailyTokenUsage {
  date      String   @id
  tokens    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
