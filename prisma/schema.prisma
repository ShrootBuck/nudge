generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QueueState {
  BACKLOG
  READY
}

enum RunState {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
}

enum ReviewStatus {
  UNREVIEWED
  VERIFIED
  INCORRECT
  UNSOLVABLE
}

model Problem {
  id        String   @id @default(cuid())
  contestId Int
  index     String // e.g. "A", "B1"
  name      String
  rating    Int?
  tags      String[] // e.g. ["dp", "greedy"]

  queueState          QueueState   @default(BACKLOG)
  runState            RunState     @default(IDLE)
  generationAttempts  Int          @default(0)
  reviewStatus        ReviewStatus @default(UNREVIEWED)
  requestedCount      Int          @default(0)
  activeBatchId       String?
  processingStartedAt DateTime?
  lastGenerationError String?      @db.Text

  // Tracks which provider/model generated this problem's content
  generatedByProvider String? // e.g. "anthropic", "openai"
  generatedByModel    String? // e.g. "claude-opus-4-6", "gpt-5-4"

  hints     Hint[]
  editorial Editorial?
  solution  Solution?
  reports   Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contestId, index])
  @@index([queueState, runState, generationAttempts])
  @@index([requestedCount, updatedAt])
}

model Hint {
  id      String @id @default(cuid())
  order   Int // 1-5
  content String @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, order])
}

model Editorial {
  id      String @id @default(cuid())
  content String @db.Text

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Solution {
  id      String @id @default(cuid())
  content String @db.Text // C++ code

  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Report {
  id     String  @id @default(cuid())
  reason String? @db.Text

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ProviderModel {
  id          String  @id @default(cuid())
  provider    String // e.g. "anthropic", "openai"
  modelId     String // e.g. "claude-opus-4-6", "gpt-5-4"
  displayName String // e.g. "Claude Opus 4.6"
  isActive    Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([provider, modelId])
}
